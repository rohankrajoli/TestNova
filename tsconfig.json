{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["client/src/*"],
      "@shared/*": ["shared/*"]
    },
    "ignoreDeprecations": "6.0",
    "strict": false,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["client/src", "server", "shared", "vite.config.ts"]
}
